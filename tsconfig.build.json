{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "rootDir": "src"
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts",
    "**/*test-helpers.ts",
    "src/**/testing/**",
    "src/test/**",
    "src/client/test/**",
    "src/client/tests/**"
  ]
}
