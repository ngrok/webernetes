{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"],
    "lib": ["ES2023", "ESNext.Disposable"],
    "outDir": "dist"
  },
  "include": ["src/**/*.ts", "vitest.config.ts", "vitest.browser.config.ts"],
  "exclude": ["node_modules", "dist"]
}
