{
  "name": "@ngrok/webernetes",
  "version": "0.1.2",
  "description": "Kubernetes that runs in the browser.",
  "keywords": [
    "browser",
    "k8s",
    "kubernetes",
    "simulator"
  ],
  "homepage": "https://github.com/ngrok/webernetes#readme",
  "bugs": {
    "url": "https://github.com/ngrok/webernetes/issues"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ngrok/webernetes.git"
  },
  "files": [
    "dist",
    "src",
    "!src/**/AGENTS.md",
    "!src/**/*.test.ts",
    "!src/**/*test-helpers.ts",
    "!src/**/testing/**",
    "!src/test/**",
    "!src/client/test/**",
    "!src/client/tests/**",
    "NOTICE"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "pnpm run clean && tsc -p tsconfig.build.json",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "pnpm run build && changeset publish",
    "demo": "pnpm --filter webernetes-demo start",
    "example:single-pod": "tsx --tsconfig examples/tsconfig.json examples/01-single-pod.ts",
    "example:node-port": "tsx --tsconfig examples/tsconfig.json examples/02-node-port-service.ts",
    "example:two-pods": "tsx --tsconfig examples/tsconfig.json examples/03-two-pods-service-dns.ts",
    "example:deployment": "tsx --tsconfig examples/tsconfig.json examples/04-deployment-service-replicas.ts",
    "example:cross-namespace": "tsx --tsconfig examples/tsconfig.json examples/05-cross-namespace-service-dns.ts",
    "example:events": "tsx --tsconfig examples/tsconfig.json examples/06-network-events-and-latency.ts",
    "fmt:check": "oxfmt --check .",
    "fmt": "oxfmt --write .",
    "k3s:setup": "tsx src/test/harnesses/kubernetes-k3s-setup-cli.ts",
    "k3s:teardown": "tsx src/test/harnesses/kubernetes-k3s-teardown.ts",
    "lint:fix": "oxlint --fix .",
    "lint": "oxlint .",
    "prepare": "husky",
    "readme:preview": "node scripts/render-readme-preview.mjs",
    "test": "node scripts/test.mjs",
    "test:node": "vitest run --config vitest.config.ts",
    "test:browser": "vitest run --config vitest.browser.config.ts",
    "test:examples": "tsx examples/run-all.ts",
    "test:all": "pnpm test",
    "test:browser:install": "playwright install chromium",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "vibe-check": "pnpm run fmt:check && pnpm run lint && pnpm run build && pnpm run typecheck && pnpm run test"
  },
  "dependencies": {
    "buffer": "^6.0.3",
    "events": "^3.3.0"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@kubernetes/client-node": "^1.4.0",
    "@testcontainers/k3s": "^12.0.1",
    "@types/cli-progress": "^3.11.6",
    "@types/node": "25.9.2",
    "@vitest/browser-playwright": "^4.1.8",
    "cli-progress": "^3.12.0",
    "etcd3": "^1.1.2",
    "husky": "9.1.7",
    "lint-staged": "17.0.7",
    "marked": "^18.0.5",
    "mermaid": "^11.15.0",
    "oxfmt": "0.54.0",
    "oxlint": "1.69.0",
    "oxlint-tsgolint": "^0.23.0",
    "playwright": "^1.60.0",
    "testcontainers": "^12.0.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "packageManager": "pnpm@11.8.0"
}
