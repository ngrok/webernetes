{
  "name": "k8s-web-simulator",
  "version": "0.1.0",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "fmt:check": "oxfmt --check .",
    "fmt": "oxfmt --write .",
    "lint:fix": "oxlint --fix .",
    "lint": "oxlint .",
    "prepare": "husky",
    "test": "pnpm test:node && pnpm test:browser",
    "test:node": "vitest run --config vitest.config.ts",
    "test:browser": "vitest run --config vitest.browser.config.ts",
    "test:all": "pnpm test",
    "test:browser:install": "playwright install chromium",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "vibe-check": "pnpm run fmt:check && pnpm run lint && pnpm run build && pnpm run typecheck && pnpm run test"
  },
  "dependencies": {
    "buffer": "^6.0.3",
    "events": "^3.3.0"
  },
  "devDependencies": {
    "@kubernetes/client-node": "^1.4.0",
    "@testcontainers/k3s": "^11.14.0",
    "@types/node": "^24.0.0",
    "@vitest/browser": "^3.2.4",
    "esbuild": "^0.25.11",
    "etcd3": "^1.1.2",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "oxfmt": "0.45.0",
    "oxlint": "1.60.0",
    "playwright": "^1.55.0",
    "testcontainers": "^11.14.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  },
  "packageManager": "pnpm@10.0.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "protobufjs"
    ]
  }
}
